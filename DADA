module counter_4bit (
    input clk,        // Clock signal
    input reset,      // Asynchronous reset
    output reg [3:0] count  // 4-bit output
);

always @(posedge clk or posedge reset) begin
    if (reset)
        count <= 4'b0000;   // Reset counter to 0
    else
        count <= count + 1; // Increment counter
end

endmodule
